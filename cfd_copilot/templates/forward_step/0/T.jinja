{% import '_macros.jinja' as foam %}{{ foam.header('volScalarField', 'T') }}

dimensions      [0 0 0 1 0 0 0];

internalField   uniform {{ '%.6g' % fluid.T }};

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform {{ '%.6g' % fluid.T }};
    }

    outlet
    {
        type            inletOutlet;
        inletValue      uniform {{ '%.6g' % fluid.T }};
        value           uniform {{ '%.6g' % fluid.T }};
    }

    bottom
    {
        type            symmetryPlane;
    }

    top
    {
        type            symmetryPlane;
    }

    obstacle
    {
        type            zeroGradient;
    }

    frontAndBack
    {
        type            empty;
    }
}

{{ foam.footer() }}
