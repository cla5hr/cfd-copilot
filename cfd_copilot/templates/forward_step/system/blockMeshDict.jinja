{% import '_macros.jinja' as foam %}{{ foam.header('dictionary', 'blockMeshDict') }}

scale   1;

vertices
(
    (0 0 {{ '%.6g' % zf }})
    ({{ '%.6g' % step_x }} 0 {{ '%.6g' % zf }})
    (0 {{ '%.6g' % step_h }} {{ '%.6g' % zf }})
    ({{ '%.6g' % step_x }} {{ '%.6g' % step_h }} {{ '%.6g' % zf }})
    ({{ '%.6g' % length }} {{ '%.6g' % step_h }} {{ '%.6g' % zf }})
    (0 {{ '%.6g' % height }} {{ '%.6g' % zf }})
    ({{ '%.6g' % step_x }} {{ '%.6g' % height }} {{ '%.6g' % zf }})
    ({{ '%.6g' % length }} {{ '%.6g' % height }} {{ '%.6g' % zf }})
    (0 0 {{ '%.6g' % zb }})
    ({{ '%.6g' % step_x }} 0 {{ '%.6g' % zb }})
    (0 {{ '%.6g' % step_h }} {{ '%.6g' % zb }})
    ({{ '%.6g' % step_x }} {{ '%.6g' % step_h }} {{ '%.6g' % zb }})
    ({{ '%.6g' % length }} {{ '%.6g' % step_h }} {{ '%.6g' % zb }})
    (0 {{ '%.6g' % height }} {{ '%.6g' % zb }})
    ({{ '%.6g' % step_x }} {{ '%.6g' % height }} {{ '%.6g' % zb }})
    ({{ '%.6g' % length }} {{ '%.6g' % height }} {{ '%.6g' % zb }})
);

blocks
(
    hex (0 1 3 2 8 9 11 10) ({{ nx_inlet }} {{ ny_lower }} 1) simpleGrading (1 1 1)
    hex (2 3 6 5 10 11 14 13) ({{ nx_inlet }} {{ ny_upper }} 1) simpleGrading (1 1 1)
    hex (3 4 7 6 11 12 15 14) ({{ nx_outlet }} {{ ny_upper }} 1) simpleGrading (1 1 1)
);

edges
(
);

defaultPatch
{
    name frontAndBack;
    type empty;
}

boundary
(
    inlet
    {
        type patch;
        faces
        (
            (0 8 10 2)
            (2 10 13 5)
        );
    }
    outlet
    {
        type patch;
        faces
        (
            (4 7 15 12)
        );
    }
    bottom
    {
        type symmetryPlane;
        faces
        (
            (0 1 9 8)
        );
    }
    top
    {
        type symmetryPlane;
        faces
        (
            (5 13 14 6)
            (6 14 15 7)
        );
    }
    obstacle
    {
        type patch;
        faces
        (
            (1 3 11 9)
            (3 4 12 11)
        );
    }
);

mergePatchPairs
(
);

{{ foam.footer() }}
